;;;; ---------------------------------------------------------------- paths

(defun lameserver--path (&rest parts)
  (expand-file-name (string-join parts "/") lameserver--root))

(defun lameserver--docs (&rest parts)
  (apply #'lameserver--path "docs" parts))

(defun lameserver--cache (&rest parts)
  (let ((f (apply #'lameserver--path ".cache" parts)))
    (make-directory (file-name-directory f) t)
    f))

;;;; ---------------------------------------------------------------- logging

(defun lameserver--log (fmt &rest args)
  (let ((msg (apply #'format fmt args)))
    (with-current-buffer (get-buffer-create "*lameserver-log*")
      (goto-char (point-max))
      (insert msg "\n"))
    (if noninteractive (princ (concat msg "\n")) (message "%s" msg))))

;;;; ---------------------------------------------------------------- tools

(defvar lameserver--tools (make-hash-table :test 'equal))

(defun lameserver--tool (name)
  "Return the executable for NAME, nil if absent (memoized per session)."
  (let ((hit (gethash name lameserver--tools 'miss)))
    (if (eq hit 'miss)
        (puthash name (executable-find name) lameserver--tools)
      hit)))

(defun lameserver--run (program &rest args)
  "Run PROGRAM with ARGS; return stdout string, or nil on failure (logged)."
  (with-temp-buffer
    (let ((status (apply #'call-process program nil t nil args)))
      (if (and (numberp status) (zerop status))
          (buffer-string)
        (lameserver--log "lameserver: %s %s failed (%s): %s"
                         program (string-join args " ") status
                         (string-trim (buffer-string)))
        nil))))

;;;; ---------------------------------------------------------------- misc

(defun lameserver--slugify (s)
  (string-trim (replace-regexp-in-string
                "[^a-z0-9]+" "-" (downcase s)) "-+" "-+"))

(defun lameserver--escape (s)
  (xml-escape-string (or s "")))

(defun lameserver--phile-hex (n) (format "0x%02x" n))

(defun lameserver--seed (string bits)
  "Deterministic integer in [0,BITS) from STRING."
  (mod (string-to-number (substring (secure-hash 'sha1 string) 0 8) 16) bits))

(defun lameserver--xorshift (state)
  "One xorshift32 step; returns new 32-bit STATE."
  (let ((s state))
    (setq s (logand #xffffffff (logxor s (ash s 13))))
    (setq s (logand #xffffffff (logxor s (ash s -17))))
    (setq s (logand #xffffffff (logxor s (ash s 5))))
    (if (zerop s) 88172645463325252 s)))

;;;; ---------------------------------------------------------------- manifest

(defconst lameserver--kw-re
  "^#\\+\\(TITLE\\|DATE\\|FILETAGS\\|PHILE\\|THUMB\\|DESCRIPTION\\|DRAFT\\):[ \t]*\\(.*?\\)[ \t]*$")

(defun lameserver--read-keywords (file)
  "Scan FILE's preamble for keywords; also record first image and word count."
  (with-temp-buffer
    (insert-file-contents file)
    (let ((kw '()) first-image)
      (save-excursion
        (let ((case-fold-search t))
          (while (re-search-forward lameserver--kw-re nil t)
            (push (cons (upcase (match-string 1)) (match-string 2)) kw))))
      (save-excursion
        (when (re-search-forward
               "\\[\\[file:\\([^]]+\\.\\(?:png\\|jpe?g\\|gif\\|webp\\)\\)\\]"
               nil t)
          (setq first-image (match-string 1))))
      (let ((words (count-words (point-min) (point-max))))
        (list :keywords kw :first-image first-image :words words)))))

(defun lameserver--scan-posts ()
  "Build `lameserver--manifest' from org/posts/*.org."
  (let ((entries '()))
    (dolist (file (directory-files (lameserver--path "org/posts") t "\\.org\\'"))
      (let* ((scan (lameserver--read-keywords file))
             (kw (plist-get scan :keywords))
             (get (lambda (k) (cdr (assoc k kw))))
             (title (or (funcall get "TITLE")
                        (file-name-base file)))
             (phile-raw (funcall get "PHILE"))
             (phile (and phile-raw (string-to-number
                                    (string-remove-prefix "0x" phile-raw) 16)))
             (date (funcall get "DATE"))
             (tags (and (funcall get "FILETAGS")
                        (split-string (funcall get "FILETAGS") ":" t "[ \t]+")))
             ;; #+DRAFT: t marks a draft; absent or nil/no/false/0 publishes
             (draft (let ((v (funcall get "DRAFT")))
                      (and v (not (member (downcase v)
                                          '("" "nil" "no" "false" "0")))))))
        (unless phile
          (error "lameserver: %s has no #+PHILE: keyword" file))
        (push (list :file file
                    :phile phile
                    :phile-hex (lameserver--phile-hex phile)
                    :slug (lameserver--slugify title)
                    :title title
                    :date date
                    :time (and date (ignore-errors (org-time-string-to-time date)))
                    :tags tags
                    :description (or (funcall get "DESCRIPTION") "")
                    :thumb (funcall get "THUMB")
                    :first-image (plist-get scan :first-image)
                    :words (plist-get scan :words)
                    :draft draft
                    :url (format "%s/phile/%s/" lameserver--site-url
                                 (lameserver--phile-hex phile)))
              entries)))
    ;; duplicates are a hard error before anything is written
    (let ((seen (make-hash-table)))
      (dolist (e entries)
        (let ((n (plist-get e :phile)))
          (when (gethash n seen)
            (error "lameserver: duplicate phile number %s (%s and %s)"
                   (lameserver--phile-hex n)
                   (plist-get (gethash n seen) :file) (plist-get e :file)))
          (puthash n e seen))))
    (setq lameserver--manifest
          (sort entries (lambda (a b) (> (plist-get a :phile)
                                         (plist-get b :phile)))))))

(defun lameserver--published ()
  "Manifest entries that are not drafts, newest first."
  (cl-remove-if (lambda (e) (plist-get e :draft)) lameserver--manifest))

(defun lameserver--manifest-entry (file)
  (cl-find (file-truename file) lameserver--manifest
           :key (lambda (e) (file-truename (plist-get e :file)))
           :test #'equal))

(defun lameserver--divider (entry)
  (aref lameserver--dividers
        (lameserver--seed (concat (plist-get entry :phile-hex)
                                  (plist-get entry :slug))
                          (length lameserver--dividers))))

