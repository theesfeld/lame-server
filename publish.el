;;; publish.el --- build lameserver.net from org sources  -*- lexical-binding: t; -*-

;; The whole static-site build for https://lameserver.net ‚ÄĒ an ANSI/BBS-style
;; blog written in org-mode.  Everything under docs/ is generated by this file:
;;
;;   org/posts/NNNN-slug.org  ->  docs/phile/0xNN/index.html
;;   org/pages/about.org      ->  docs/about/index.html
;;   org/media/               ->  docs/media/
;;   assets/                  ->  docs/assets/  (static/ copied to docs/ root)
;;   + board listing, category pages, feed.xml, search.json
;;
;; Images in posts are converted to colored ANSI art at build time (chafa),
;; parsed from SGR escapes into HTML by pure elisp.  Titles and section
;; headings are set in lameblock, the site's own hand-drawn block font.
;; Missing tools degrade gracefully: no chafa -> plain <img>, no htmlize ->
;; unfontified code blocks.
;;
;; Entry points:
;;   M-x lameserver-publish        build docs/
;;   M-x lameserver-deploy         build + git add/commit/push
;;   M-x lameserver-clean          wipe docs/ + .cache/
;;   emacs --batch -l publish.el -f lameserver-publish-batch

;;; Code:

