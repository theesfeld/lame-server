(defun lameserver--page-shell (&rest args)
  "Full HTML page.  ARGS plist: :title :desc :canonical :masthead-right
:active :loc :body :extra-head :body-script"
  (let ((title (plist-get args :title))
        (desc (or (plist-get args :desc) "lameserver.net ‚ÄĒ a bulletin board"))
        (canonical (plist-get args :canonical)))
    (concat
     "<!doctype html>\n<html lang=\"en\">\n<head>\n"
     "<meta charset=\"utf-8\">\n"
     "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
     (format "<title>%s</title>\n" (lameserver--escape title))
     (format "<meta name=\"description\" content=\"%s\">\n" (lameserver--escape desc))
     (when canonical
       (format "<link rel=\"canonical\" href=\"%s\">\n" canonical))
     "<link rel=\"alternate\" type=\"application/rss+xml\" title=\"lameserver\" href=\"/feed.xml\">\n"
     "<link rel=\"icon\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='13' font-size='13' fill='%23ff79c6'>‚Ėď</text></svg>\">\n"
     "<link rel=\"stylesheet\" href=\"/assets/css/site.css\">\n"
     "<link rel=\"stylesheet\" href=\"/assets/css/dracula.css\">\n"
     (or (plist-get args :extra-head) "")
     "</head>\n<body>\n"
     "<header class=\"site-header\">"
     "<a class=\"skip\" href=\"#content\">skip to content</a>"
     "<!-- the space above can be used to advertise your lame BBS if you so desire. . .  - stc/acid, 1995 -->"
     "<div id=\"banner\" role=\"img\" aria-label=\"lameserver\">"
     (lameserver--block-logo "lameserver" nil 90)
     "</div>"
     (lameserver--masthead (or (plist-get args :masthead-right) "est. 2026"))
     (lameserver--menu-html (plist-get args :active) (plist-get args :loc))
     "</header>\n"
     "<main id=\"content\">\n"
     (plist-get args :body)
     "\n</main>\n"
     (lameserver--footer)
     "<script src=\"/assets/js/header.js\" defer></script>\n"
     (or (plist-get args :body-script) "")
     "</body>\n</html>\n")))

;;;; ---------------------------------------------------------------- post template

(defun lameserver--reading-time (words)
  (max 1 (round (/ (or words 0) 220.0))))

(defun lameserver--share-html (entry)
  (let* ((url (plist-get entry :url))
         (eurl (url-hexify-string url))
         (etitle (url-hexify-string (plist-get entry :title))))
    (concat
     "<section class=\"share\" aria-label=\"share\">"
     (format "<div class=\"share-rail\" aria-hidden=\"true\">.oO( share this phile )Oo.</div>")
     "<div class=\"share-links\">"
     (format "<a rel=\"noopener\" target=\"_blank\" href=\"https://twitter.com/intent/tweet?url=%s&amp;text=%s\">[x]</a>" eurl etitle)
     (format "<button type=\"button\" class=\"share-fedi\" data-url=\"%s\" data-title=\"%s\">[fedi]</button>"
             (lameserver--escape url) (lameserver--escape (plist-get entry :title)))
     (format "<a rel=\"noopener\" target=\"_blank\" href=\"https://news.ycombinator.com/submitlink?u=%s&amp;t=%s\">[hn]</a>" eurl etitle)
     (format "<a rel=\"noopener\" target=\"_blank\" href=\"https://www.reddit.com/submit?url=%s&amp;title=%s\">[reddit]</a>" eurl etitle)
     (format "<a rel=\"noopener\" target=\"_blank\" href=\"https://lobste.rs/stories/new?url=%s&amp;title=%s\">[lobsters]</a>" eurl etitle)
     (format "<button type=\"button\" class=\"share-copy\" data-url=\"%s\">[copy url]</button>"
             (lameserver--escape url))
     "</div></section>")))

(defun lameserver--neighbor-rail (entry)
  (let* ((posts (lameserver--published))
         (pos (cl-position entry posts :test #'eq))
         (next (and pos (> pos 0) (nth (1- pos) posts)))          ; newer
         (prev (and pos (nth (1+ pos) posts))))                   ; older
    (concat
     "<nav class=\"phile-rail\" aria-label=\"neighboring philes\">"
     (if prev
         (format "<a id=\"prev-phile\" href=\"/phile/%s/\">&#8592; %s %s</a>"
                 (plist-get prev :phile-hex) (plist-get prev :phile-hex)
                 (lameserver--escape (plist-get prev :title)))
       "<span class=\"dim\">&#8592; older: none</span>")
     "<a href=\"/board/\">[board]</a>"
     (if next
         (format "<a id=\"next-phile\" href=\"/phile/%s/\">%s %s &#8594;</a>"
                 (plist-get next :phile-hex) (plist-get next :phile-hex)
                 (lameserver--escape (plist-get next :title)))
       "<span class=\"dim\">newer: none &#8594;</span>")
     "</nav>")))

(defun lameserver--html-template (contents info)
  "Full page for a post (or page) exported through the derived backend."
  (let* ((file (plist-get info :input-file))
         (entry (lameserver--manifest-entry file)))
    (if (null entry)
        ;; a plain page (about etc.): lighter chrome, named in the menu bar
        (let ((title (org-export-data (plist-get info :title) info)))
          (lameserver--page-shell
           :title (format "%s ¬∑ lameserver" title)
           :active (lameserver--slugify title)
           :loc title
           :body (concat (format "<h1 class=\"vh\">%s</h1>" (lameserver--escape title))
                         "<article class=\"phile-body\">" contents "</article>")
           :body-script "<script src=\"/assets/js/phile.js\" defer></script>"))
      (let ((title (plist-get entry :title))
            (divider (lameserver--divider entry)))
        (lameserver--page-shell
         :title (format "%s ¬∑ lameserver" title)
         :desc (plist-get entry :description)
         :canonical (plist-get entry :url)
         :masthead-right (format "phile %s of %s"
                                 (plist-get entry :phile-hex)
                                 (lameserver--phile-hex
                                  (plist-get (car (lameserver--published)) :phile)))
         :active "board"
         :loc (format "board ‚Äļ %s" (plist-get entry :phile-hex))
         :body (concat
                (lameserver--phile-head entry)
                "<article class=\"phile-body\">" contents "</article>"
                (format "<div class=\"divider hue-%s\" aria-hidden=\"true\">%s</div>"
                        (lameserver--hue entry) divider)
                (lameserver--share-html entry)
                (lameserver--neighbor-rail entry))
         :body-script "<script src=\"/assets/js/phile.js\" defer></script>")))))

(org-export-define-derived-backend 'lameserver-html 'html
  :translate-alist '((template . lameserver--html-template)
                     (link . lameserver--html-link)
                     (headline . lameserver--html-headline))
  :options-alist '((:phile "PHILE" nil nil t)
                   (:thumb "THUMB" nil nil t)
                   (:draft "DRAFT" nil nil t)))

;;;; ---------------------------------------------------------------- exporting

(defconst lameserver--export-plist
  '(:section-numbers t
    :with-toc nil
    :with-author nil
    :with-email nil
    :with-creator nil
    :with-date nil
    :with-sub-superscript {}
    :html-doctype "html5"
    :html-html5-fancy t))

(defmacro lameserver--with-export-env (&rest body)
  "Run BODY with export options safely scoped (daemon hygiene)."
  `(let ((org-export-use-babel nil)
         (org-confirm-babel-evaluate t)
         (org-html-htmlize-output-type
          (if (require 'htmlize nil t) 'css nil))
         (org-export-with-broken-links 'mark)
         (coding-system-for-write 'utf-8)
         (make-backup-files nil)
         (system-time-locale "C")
         ;; htmlize fontifies src blocks in temp buffers; a daemon's UI mode
         ;; hooks (indent-bars etc.) break or pollute that ‚ÄĒ export wants
         ;; pure font-lock, so run every mode bare
         (prog-mode-hook nil)
         (text-mode-hook nil)
         (org-mode-hook nil))
     ,@body))

(defun lameserver--export-file (file outfile)
  "Export org FILE to OUTFILE through the lameserver backend."
  (make-directory (file-name-directory outfile) t)
  (let ((visiting (find-buffer-visiting file))
        (lameserver--section-index 0))     ; alternation restarts each phile
    (with-current-buffer (or visiting (find-file-noselect file))
      (unwind-protect
          (org-export-to-file 'lameserver-html outfile
            nil nil nil nil lameserver--export-plist)
        (unless visiting (kill-buffer (current-buffer)))))))

(defun lameserver--post-plaintext (file)
  "Plaintext body of FILE for the search index (truncated)."
  (let ((visiting (find-buffer-visiting file)))
    (with-current-buffer (or visiting (find-file-noselect file))
      (unwind-protect
          (let ((txt (org-export-as 'ascii nil nil t
                                    '(:with-toc nil :section-numbers nil))))
            (substring txt 0 (min 2000 (length txt))))
        (unless visiting (kill-buffer (current-buffer)))))))

;;;; ---------------------------------------------------------------- signing

(defun lameserver--sign-posts ()
  "Detach-sign every published phile's org source into its output dir.
Each entry gains :sig (the signing key fingerprint) on success.  Readers
verify with: gpg --verify source.org.asc source.org"
  (if (not (lameserver--tool "gpg"))
      (lameserver--log "lameserver: gpg not found ‚ÄĒ philes ship unsigned")
    (dolist (e (lameserver--published))
      (let* ((src (plist-get e :file))
             (dir (lameserver--docs "phile" (plist-get e :phile-hex)))
             (dst (expand-file-name "source.org" dir))
             (asc (concat dst ".asc")))
        (make-directory dir t)
        (copy-file src dst t)
        (when (or (not (file-exists-p asc))
                  (file-newer-than-file-p src asc))
          (apply #'lameserver--run "gpg"
                 (append '("--batch" "--yes" "--armor" "--detach-sign")
                         (and lameserver--gpg-key
                              (list "--local-user" lameserver--gpg-key))
                         (list "--output" asc dst))))
        (when (file-exists-p asc)
          (when-let* ((v (lameserver--run "gpg" "--status-fd" "1"
                                          "--verify" asc dst)))
            (when (string-match "VALIDSIG \\([0-9A-F]+\\)" v)
              (plist-put e :sig (match-string 1 v)))))
        (unless (plist-get e :sig)
          (lameserver--log "lameserver: WARNING %s is unsigned"
                           (plist-get e :phile-hex)))))
    ;; ship the public key so signatures are verifiable
    (when-let* ((entry (cl-find-if (lambda (e) (plist-get e :sig))
                                   (lameserver--published)))
                (pub (lameserver--run "gpg" "--armor" "--export"
                                      (plist-get entry :sig))))
      (with-temp-file (lameserver--docs "pubkey.asc") (insert pub)))))

;;;; ---------------------------------------------------------------- thumbs

(defun lameserver--thumb-html (entry)
  "Board-listing thumbnail: #+THUMB, else first image, else emblem."
  (let* ((file (plist-get entry :file))
         (src (or (plist-get entry :thumb) (plist-get entry :first-image)))
         (abs (and src (expand-file-name src (file-name-directory file)))))
    (or (and abs (file-exists-p abs)
             (lameserver--ansi-render
              abs (format "th%s" (plist-get entry :phile-hex))
              lameserver--thumb-size "half+space"))
        (lameserver--emblem (concat (plist-get entry :phile-hex)
                                    (plist-get entry :slug))))))

;;;; ---------------------------------------------------------------- board & categories

(defun lameserver--listing-row (entry)
  "One board entry as a FILE_ID.DIZ-style card: thumb as the logo,
title as the release name, block rules top and bottom."
  (let ((hex (plist-get entry :phile-hex))
        (date (if (plist-get entry :time)
                  (format-time-string "%Y-%m-%d" (plist-get entry :time))
                "undated")))
    (format (concat "<li class=\"row hue-%s\">"
                    "<span class=\"row-hex\" aria-hidden=\"true\">‚Ē§ %s ‚Ēú</span>"
                    "<span class=\"row-thumb\" aria-hidden=\"true\">%s</span>"
                    "<span class=\"row-head\">"
                    "<a class=\"row-link\" href=\"/phile/%s/\">"
                    "<span class=\"row-title\">%s</span></a>%s</span>"
                    "<span class=\"row-desc\">%s</span>"
                    "<span class=\"row-foot\"><span class=\"row-date\">%s</span>"
                    "<span class=\"row-tags\">%s</span></span>"
                    "</li>")
            (lameserver--hue entry)
            hex
            (lameserver--thumb-html entry)
            hex
            (lameserver--escape (plist-get entry :title))
            (if (plist-get entry :sig)
                " <span class=\"sig ok\" title=\"signed\">&#10003;</span>" "")
            (lameserver--escape (plist-get entry :description))
            date
            (mapconcat (lambda (tag)
                         (format "<a class=\"tag\" href=\"/category/%s/\">[%s]</a>"
                                 (lameserver--slugify tag) (lameserver--escape tag)))
                       (plist-get entry :tags) " "))))

(defun lameserver--listing-page (title posts out-dir &optional lead)
  (let ((body
         (concat
          (format "<h1 class=\"vh\">%s</h1>" (lameserver--escape title))
          (or lead "")
          "<div class=\"board-bar\"><label id=\"search\" class=\"search-prompt\">"
          "search&gt; <input type=\"search\" id=\"board-search\" autocomplete=\"off\" "
          "spellcheck=\"false\" aria-label=\"search philes\"></label>"
          "<span class=\"board-hint\" aria-hidden=\"true\">j/k move ¬∑ enter opens ¬∑ / search ¬∑ ? help</span></div>"
          "<ul class=\"board\" id=\"board-list\">"
          (mapconcat #'lameserver--listing-row posts "\n")
          "</ul>")))
    (make-directory out-dir t)
    (with-temp-file (expand-file-name "index.html" out-dir)
      (insert (lameserver--page-shell
               :title (format "%s ¬∑ lameserver" title)
               :active "board"
               :loc title
               :masthead-right (format "%d philes on file" (length posts))
               :body body
               :body-script "<script src=\"/assets/js/board.js\" defer></script>")))))

(defun lameserver--write-board ()
  (lameserver--listing-page "the board" (lameserver--published)
                            (lameserver--docs "board")))

(defun lameserver--all-tags ()
  (let ((tags '()))
    (dolist (e (lameserver--published))
      (dolist (tag (plist-get e :tags))
        (cl-pushnew tag tags :test #'equal)))
    (sort tags #'string<)))

(defun lameserver--write-categories ()
  (dolist (tag (lameserver--all-tags))
    (let ((posts (cl-remove-if-not
                  (lambda (e) (member tag (plist-get e :tags)))
                  (lameserver--published))))
      (lameserver--listing-page
       (format "category: %s" tag) posts
       (lameserver--docs "category" (lameserver--slugify tag))
       (format "<p class=\"lead\"><a href=\"/board/\">&#8592; all philes</a></p>")))))

;;;; ---------------------------------------------------------------- feed & search

(defun lameserver--rfc822 (time)
  (let ((system-time-locale "C"))
    (format-time-string "%a, %d %b %Y %H:%M:%S %z" (or time (current-time)))))

(defun lameserver--write-feed ()
  (with-temp-file (lameserver--docs "feed.xml")
    (insert "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
            "<rss version=\"2.0\" xmlns:atom=\"http://www.w3.org/2005/Atom\">\n<channel>\n"
            "<title>lameserver</title>\n"
            (format "<link>%s/</link>\n" lameserver--site-url)
            "<description>philes from the board at lameserver.net</description>\n"
            (format "<atom:link href=\"%s/feed.xml\" rel=\"self\" type=\"application/rss+xml\"/>\n"
                    lameserver--site-url)
            (format "<lastBuildDate>%s</lastBuildDate>\n" (lameserver--rfc822 nil)))
    (dolist (e (lameserver--published))
      (insert "<item>\n"
              (format "<title>%s</title>\n" (lameserver--escape (plist-get e :title)))
              (format "<link>%s</link>\n" (plist-get e :url))
              (format "<guid isPermaLink=\"true\">%s</guid>\n" (plist-get e :url))
              (format "<pubDate>%s</pubDate>\n" (lameserver--rfc822 (plist-get e :time)))
              (format "<description>%s</description>\n"
                      (lameserver--escape (plist-get e :description)))
              "</item>\n"))
    (insert "</channel>\n</rss>\n")))

(defun lameserver--write-search-json ()
  (let ((items
         (mapcar
          (lambda (e)
            `((phile . ,(plist-get e :phile-hex))
              (title . ,(plist-get e :title))
              (url . ,(format "/phile/%s/" (plist-get e :phile-hex)))
              (date . ,(if (plist-get e :time)
                           (format-time-string "%Y-%m-%d" (plist-get e :time))
                         ""))
              (tags . ,(vconcat (or (plist-get e :tags) [])))
              (description . ,(plist-get e :description))
              (text . ,(or (ignore-errors
                             (lameserver--post-plaintext (plist-get e :file)))
                           ""))))
          (lameserver--published))))
    (with-temp-file (lameserver--docs "search.json")
      (insert (json-serialize (vconcat items))))))

;;;; ---------------------------------------------------------------- static & prune

(defun lameserver--copy-tree (src dst)
  (when (file-directory-p dst) (delete-directory dst t))
  (when (file-directory-p src) (copy-directory src dst t t t)))

(defun lameserver--write-static ()
  ;; assets (minus static/) -> docs/assets.  Media: only audio/video ship ‚ÄĒ
  ;; images exist solely as build inputs for the ANSI conversion.
  (let ((tmp-static (lameserver--path "assets/static")))
    (lameserver--copy-tree (lameserver--path "assets") (lameserver--docs "assets"))
    (delete-directory (lameserver--docs "assets/static") t)
    (lameserver--copy-tree (lameserver--path "org/media") (lameserver--docs "media"))
    (dolist (img (ignore-errors
                   (directory-files-recursively
                    (lameserver--docs "media")
                    "\\.\\(?:png\\|jpe?g\\|gif\\|webp\\|svg\\)\\'")))
      (delete-file img))
    ;; splash + CNAME + .nojekyll at the docs root
    (copy-file (expand-file-name "index.html" tmp-static)
               (lameserver--docs "index.html") t)
    (copy-file (expand-file-name "CNAME" tmp-static)
               (lameserver--docs "CNAME") t)
    (with-temp-file (lameserver--docs ".nojekyll"))))

(defun lameserver--prune ()
  "Delete published dirs whose source is gone or re-drafted."
  (let ((live-philes (mapcar (lambda (e) (plist-get e :phile-hex))
                             (lameserver--published)))
        (live-tags (mapcar #'lameserver--slugify (lameserver--all-tags))))
    (dolist (dir (ignore-errors
                   (directory-files (lameserver--docs "phile") t "\\`0x")))
      (unless (member (file-name-nondirectory dir) live-philes)
        (lameserver--log "lameserver: pruning %s" dir)
        (delete-directory dir t)))
    (dolist (dir (ignore-errors
                   (directory-files (lameserver--docs "category") t "\\`[^.]")))
      (unless (member (file-name-nondirectory dir) live-tags)
        (lameserver--log "lameserver: pruning %s" dir)
        (delete-directory dir t)))))

;;;; ---------------------------------------------------------------- orchestrator

(defun lameserver-publish ()
  "Build the whole site into docs/."
  (interactive)
  (let ((t0 (current-time)))
    (setq lameserver--build-stamp
          (let ((system-time-locale "C"))
            (format-time-string "%Y-%m-%d %H:%M UTC" nil t))
          lameserver--image-counter 0)
    (lameserver--scan-posts)
    (lameserver--with-export-env
     (unless (lameserver--tool "chafa")
       (lameserver--log "lameserver: chafa not found ‚ÄĒ images ship as plain <img>"))
     (unless (featurep 'htmlize)
       (lameserver--log "lameserver: htmlize not found ‚ÄĒ code blocks unfontified"))
     (lameserver--write-static)
     (lameserver--sign-posts)
     (dolist (e (lameserver--published))
       (lameserver--export-file
        (plist-get e :file)
        (lameserver--docs "phile" (plist-get e :phile-hex) "index.html")))
     (dolist (page (ignore-errors
                     (directory-files (lameserver--path "org/pages") t "\\.org\\'")))
       (lameserver--export-file
        page (lameserver--docs (file-name-base page) "index.html")))
     (lameserver--write-board)
     (lameserver--write-categories)
     (lameserver--write-feed)
     (lameserver--write-search-json)
     (lameserver--prune))
    (lameserver--log "lameserver: built %d philes in %.1fs"
                     (length (lameserver--published))
                     (float-time (time-subtract (current-time) t0)))))

(defun lameserver-publish-batch ()
  "Batch entry point: build and exit non-zero on error."
  (lameserver-publish))

(defun lameserver-deploy ()
  "Build, commit, and push."
  (interactive)
  (lameserver-publish)
  (let ((default-directory lameserver--root))
    (if (string-blank-p (or (lameserver--run "git" "status" "--porcelain") ""))
        (lameserver--log "lameserver: nothing to deploy ‚ÄĒ tree is clean")
      (or (and (lameserver--run "git" "add" "-A" "--" "org" "assets" "docs"
                                "publish.el" ".dir-locals.el" ".gitignore")
               (lameserver--run "git" "commit" "-m"
                                (format "publish: %s" lameserver--build-stamp))
               (lameserver--run "git" "push")
               (prog1 t
                 (lameserver--log "lameserver: deployed ‚Üí %s/board/" lameserver--site-url)))
          (user-error "lameserver: deploy failed ‚ÄĒ see *lameserver-log*")))))

(defun lameserver-clean ()
  "Delete docs/ and .cache/ after confirming."
  (interactive)
  (when (or noninteractive
            (yes-or-no-p "Delete docs/ and .cache/ entirely? "))
    (dolist (d (list (lameserver--docs) (lameserver--path ".cache")))
      (when (file-directory-p d) (delete-directory d t)))
    (lameserver--log "lameserver: clean")))

(provide 'lameserver-publish)
